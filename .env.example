# Per-worktree ports (default: 0)
# Derived: DJANGO_PORT = 8000 + PORT_OFFSET, DYNAMODB_LOCAL_PORT = 8001 + PORT_OFFSET
PORT_OFFSET=0

# Explicit ports override the derived values above
DJANGO_PORT=8000
DYNAMODB_LOCAL_PORT=8001

# DynamoDB endpoint for app code (Django, Lambda, scripts)
# Defaults to http://localhost:{DYNAMODB_LOCAL_PORT} if not set
DYNAMODB_ENDPOINT_URL=http://localhost:8001

# AWS credentials (dummy for DynamoDB Local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Comma-separated list for production (e.g. uptime.example.com)
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
